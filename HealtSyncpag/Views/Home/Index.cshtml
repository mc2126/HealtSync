<!-- ═══════════════════════════════════════════
     CTA / COMPRAR
     ═══════════════════════════════════════════ -->
<section class="hs-cta" id="comprar">
    <div class="hs-container">
        <div class="hs-cta__inner">
            <div>
                <span class="hs-eyebrow" style="color:var(--teal);">Oferta de lanzamiento</span>
                <h2 class="hs-cta__title">HealthSync SmartBand Pro</h2>
                <p class="hs-cta__sub">Incluye pulsera, cargador magnético, correa extra y 1 año de garantía.</p>
                <div class="hs-cta__price">
                    <span class="hs-cta__old-price">$129.99</span>
                    <span class="hs-cta__current-price">$89.99</span>
                </div>
            </div>
            <div class="hs-cta__action">
                <form asp-controller="Cart" asp-action="Add" method="post">
                    <input type="hidden" name="Id" value="healthsync-watch-001" />
                    <input type="hidden" name="Name" value="HealthSync SmartBand Pro" />
                    <input type="hidden" name="Price" value="89.99" />
                    <input type="hidden" name="Quantity" value="1" />
                    <button type="submit" class="hs-btn hs-btn--primary hs-btn--lg" id="btn-buy-cta">
                        🛒 Agregar al carrito
                    </button>
                </form>
                <span class="hs-cta__disclaimer">Envío gratis a todo El Salvador · Pago seguro</span>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Manejo AJAX de los formularios de compra
        document.querySelectorAll('form[action*="Cart/Add"]').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                const formData = new FormData(this);
                fetch('/Cart/Add', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        // Actualizar contador
                        const countEl = document.getElementById('cart-count');
                        if (countEl) {
                            countEl.textContent = data.count;
                            countEl.style.display = 'inline-block';
                        }
                        // Mostrar toast
                        showToast('✓ Producto agregado al carrito');
                    }
                })
                .catch(err => {
                    console.error(err);
                    this.submit(); // Fallback
                });
            });
        });

        function showToast(message) {
            const toast = document.createElement('div');
            toast.textContent = message;
            toast.style.cssText = `
                position: fixed;
                bottom: 24px;
                right: 24px;
                background: #0B1F3A;
                color: white;
                padding: 16px 24px;
                border-radius: 12px;
                box-shadow: 0 8px 24px rgba(0,0,0,0.2);
                z-index: 9999;
                font-family: Inter, sans-serif;
                font-size: 0.95rem;
                animation: fadeUp 0.3s ease;
                border-left: 4px solid #00C9B1;
            `;
            document.body.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transition = 'opacity 0.3s';
                setTimeout(() => toast.remove(), 300);
            }, 2500);
        }
    </script>
}